
# nginx
NGINX_DATA_PATH=/home/ubuntu
FRONTEND_PAGE=/home/ubuntu

# es（16C64G：MEM_LIMIT 是 ES 容器内存上限，8GB；JVM 堆在 compose 里为 4g）
ELASTIC_PASSWORD=infini_rag_flow
STACK_VERSION=8.11.3
MEM_LIMIT=8589934592
TIMEZONE='Asia/Shanghai'

# ===== 阿里云 DashScope（默认后端；rerank 只能用它，embedding 也建议用它）=====
# rerank(gte-rerank) 是 DashScope 专有接口，必须填 Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL="https://ws-lvpecbcqo3dp5bjg.cn-beijing.maas.aliyuncs.com/compatible-mode/v1"

# ===== 对话 LLM（可选：换成任意 OpenAI 兼容服务）=====
# 不填则回退用上面的 DASHSCOPE_*。示例为 apidock：
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://apidock.ai/v1
LLM_MODEL=deepseek-r1

# ===== 向量 Embedding（可选：换成其他 OpenAI 兼容 embedding 服务）=====
# ⚠️ 换 embedding 会改变向量维度(默认1024)，必须重建 ES 知识库，否则检索失效。
# 不填则回退用 DASHSCOPE_* + text-embedding-v3。
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-v3


# docker compose 内部服务名（用 compose 部署时保持默认即可）
DATABASE_URL=postgresql://postgres:pg123456@gsk_pg:5432/gsk
ES_HOST=http://es01:9200
