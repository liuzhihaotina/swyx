
# nginx
NGINX_DATA_PATH=/home/ubuntu
FRONTEND_PAGE=/home/ubuntu

# es（4G 内存友好：MEM_LIMIT 是 ES 容器内存上限，1.5GB；不要再改回 8G）
ELASTIC_PASSWORD=infini_rag_flow
STACK_VERSION=8.11.3
MEM_LIMIT=1610612736
TIMEZONE='Asia/Shanghai'

# 阿里云 DashScope（embedding / rerank / 对话都走这里，必须填自己的 Key）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# docker compose 内部服务名（用 compose 部署时保持默认即可）
DATABASE_URL=postgresql://postgres:pg123456@gsk_pg:5432/gsk
ES_HOST=http://es01:9200
